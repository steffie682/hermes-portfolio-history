# Local development only. Do not commit real credentials.
# Runtime role: NOSUPERUSER, NOBYPASSRLS, no schema ownership.
DATABASE_URL=postgresql://portfolio_app:***@localhost:5432/portfolio_history
# DDL/migration role. Do not expose this URL to the running application.
DATABASE_MIGRATION_URL=postgresql://portfolio_migrator:***@localhost:5432/portfolio_history
# Generate a random value with at least 32 characters. Never reuse this example text.
AUTH_SECRET=<generate-a-random-secret-of-at-least-32-characters>
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_ID=localhost
